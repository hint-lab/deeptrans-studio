#  Environment variables for DeepTrans Studio
NODE_ENV=production
# Application host
HOSTNAME=0.0.0.0
# Application port
PORT=3000
# NextAuth.js 配置
NEXTAUTH_URL="http://localhost"
NEXTAUTH_SECRET=<your-nextauth-secret-here>
# 设置为yes启用演示账户，设置为no启用注册登录
IS_DEMO=yes
#openssl rand -base64 32
AUTH_TRUST_HOST=true
AUTH_SESSION_MAX_AGE=3600
# 数据库配置
DB_CONTAINER_NAME=<your-db-container-name-here>
POSTGRES_USER=<your-postgres-user-here>
POSTGRES_PASSWORD=<your-postgres-password-here>
POSTGRES_DB=deeptrans
DATABASE_URL="postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_CONTAINER_NAME}:5432/${POSTGRES_DB}?schema=public"
DIRECT_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_CONTAINER_NAME}:5432/${POSTGRES_DB}?schema=public"

# Object Storage 文件存储配置
# STORAGE_TYPE=minio 使用自建 MinIO；STORAGE_TYPE=cos 使用腾讯云 COS。
STORAGE_TYPE=minio

# MinIO/S3 兼容配置
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=deeptrans
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=<your-minio-access-key-here>
MINIO_SECRET_KEY=<your-minio-secret-key-here>
MINIO_BROWSER_REDIRECT_URL=http://127.0.0.1:9001
MINIO_MAX_CONNECTIONS=10
MINIO_MAX_RETRIES=3
MINIO_RETRY_DELAY=1000
MINIO_TIMEOUT=30000
#minio为docker-compose中minio服务的名称
STORAGE_ENDPOINT=minio
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=<your-storage-access-key-here>
STORAGE_SECRET_KEY=<your-storage-secret-key-here>
STORAGE_BUCKET=deeptrans
STORAGE_UPLOAD_URL_EXPIRES_SECONDS=86400
STORAGE_DOWNLOAD_URL_EXPIRES_SECONDS=86400

# 腾讯云 COS 配置（启用时设置 STORAGE_TYPE=cos）
# COS_SECRET_ID=<your-cos-secret-id>
# COS_SECRET_KEY=<your-cos-secret-key>
# COS_BUCKET=deeptrans-1250000000
# COS_REGION=ap-guangzhou
# 可选：如果 COS_BUCKET 未带 appid 后缀，可填 COS_APP_ID 自动拼成 bucket-appid
# COS_APP_ID=1250000000
# 可选：自定义加速域名/CDN 域名，不填则使用 COS 默认域名
# COS_DOMAIN=
# COS_USE_SSL=true

# OAuth 配置 - GitHub
GITHUB_CLIENT_ID=<your-github-client-id-here>  # 用实际的 GitHub 客户端 ID 替换
GITHUB_CLIENT_SECRET=<your-github-client-secret-here>  # 用实际的 GitHub 客户端 secret 替换

# OCR API 认证配置
OCR_AUTH_URL="http://localhost:5000/api/v1/auth/token"
OCR_BASE_URL="http://localhost:5000/api/v1/ocr/url?detailed=true"
OCR_CLIENT_ID=<your-ocr-client-id-here>
OCR_CLIENT_SECRET=<your-ocr-client-secret-here>

# Auth.js secret 配置
AUTH_SECRET=<your-auth-secret-here>

# OpenAI API 配置
OPENAI_API_KEY=<>your-openai-api-key-here>
OPENAI_BASE_URL=<your-openai-base-url-here>
OPENAI_API_MODEL=<your-openai-model-here>

# SMTP 邮件验证码配置
# 163 邮箱示例：用户名里的 @ 需要 URL 编码为 %40；密码使用客户端授权码，不使用邮箱登录密码。
# EMAIL_SERVER=smtps://deeptrans_studio%40163.com:<your-163-authorization-code>@smtp.163.com:465
# EMAIL_FROM="DeepTrans Studio <deeptrans_studio@163.com>"
EMAIL_SERVER=<your-email-server>
EMAIL_FROM=<your-email-from>

# === Valkey Configuration (Redis protocol compatible) ===
# valkey:6379 中 valkey 为 docker-compose 中 Valkey 服务名称
REDIS_URL=redis://valkey:6379
#REDIS_URL=redis://localhost:6379

# === Embedding Provider ===
OPENAI_EMBED_MODEL=doubao-embedding-text-240715

# Dictionary API URL
DICTIONARY_API_URL=http://localhost:3000

# Application host for external access
STUDIO_HOST=<your-domain-here>
#日志中禁用的DEBUG type
LOGGER_DISABLE_DEBUG_TYPES=middleware:auth
